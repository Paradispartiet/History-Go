{
  "schema": "civication_mail_plan_v1",
  "id": "barnehageassistent_v1",
  "category": "sosial_laering",
  "role_scope": "barnehageassistent",
  "description": "Den lange dagen på avdelingen: en konkret Day 1 for barnehageassistent/pedagogisk medarbeider.",
  "arc": {
    "from": "Du åpner avdelingen med stram bemanning og et barn som ikke slipper forelderen.",
    "to": "Du avslutter dagen med spor av trygghet, observasjon og egen profesjonell grense.",
    "core_questions": [
      "Hva slags voksen er du når dagen blir for lang?",
      "Hvordan gjør du omsorg til praksis under tidspress?"
    ]
  },
  "outcome_rules": {
    "mastery": {
      "signals": [
        "trygg overgang",
        "presis observasjon",
        "varm grensesetting"
      ]
    },
    "stagnated": {
      "signals": [
        "barn overses",
        "dokumentasjon blir synsing"
      ]
    },
    "collapse": {
      "signals": [
        "slitasje styrer stemmen",
        "barnets beste taper mot flyt"
      ]
    }
  },
