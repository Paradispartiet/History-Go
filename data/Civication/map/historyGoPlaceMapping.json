  "perPlaceMappingTemplate": {
    "id": "map_<historyGoPlaceId>",
    "historyGoPlaceId": "<must_match_existing_place_id>",
    "historyGoSourceFile": "<source file from manifest>",
    "civicationPlaceId": "civi_<clean_place_id>",
    "buildingTypeId": "<from sourceFileMappings.defaultBuildingTypeId or custom>",
    "mapRole": "<from sourceFileMappings.mapRole or custom>",
    "visibleAs": "<from sourceFileMappings.visibleAs or custom>",
    "socialFunctions": [
      "<one>",
      "<per>",
      "<line>"
    ],
    "phaseTypes": [
      "<one>",
      "<per>",
      "<line>"
    ],
    "groundhopperRelevant": false,
    "needsVerification": true
  }
