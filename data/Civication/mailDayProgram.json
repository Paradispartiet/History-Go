        "label": "Kveld",
        "clock_anchor": "19:00",
        "target_minutes": 10,
        "mail_slots": [
          {
            "slot": "phase_evening",
            "type": "phase",
            "count": 1,
            "purpose": "Kveldsbolk etter middag."
          },
          {
            "slot": "learning_or_hobby",
            "type": "knowledge",
            "count": 1,
            "purpose": "Læring, fagstoff eller hobby."
          },
          {
            "slot": "rest_or_social",
            "type": "micro_choice",
            "count": 1,
            "purpose": "Hvile eller sosialt valg."
          },
          {
            "slot": "consequence_mail",
            "type": "consequence",
            "count": 1,
