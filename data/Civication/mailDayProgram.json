{
  "schema": "civication_mail_day_program_v1",
  "version": 1,
  "description": "Daglig leserytme for Civication-mails. Målet er at en spilldag skal føles som en hel arbeidsdag og gi omtrent 60 minutters samlet lesing, vurdering og valg.",
  "principle": [
    "MailPlan styrer langsiktig rolleprogresjon.",
    "MailDayProgram styrer hvor mye innhold som skal fylle én arbeidsdag.",
    "En dag skal ikke bare ha én jobbmail. Den skal ha en rytme av hovedmailer, korte driftsmailer, konflikter, oppfølginger, phase-events og dagsoppsummering.",
    "Målet er ikke flest mulig popup-varsler, men nok tekst, kontekst og valg til at arbeidsdagen tar omtrent én time å lese grundig."
  ],
  "reading_model": {
    "target_total_minutes_per_day": 60,
    "target_word_count_per_day_min": 8500,
    "target_word_count_per_day_max": 12000,
    "assumed_words_per_minute": 180,
    "choice_thinking_multiplier": 1.25,
    "notes": [
      "Ren lesing på 180 ord/min gir 10 800 ord på 60 minutter.",
      "Fordi spilleren også vurderer valg, konsekvenser og sammenheng, kan faktisk tekstmengde være lavere enn ren lesetid tilsier.",
      "Målet bør derfor være 8 500–12 000 ord samlet tekst per spilldag, inkludert subject, summary, situation, choices og feedback."
    ]
  },
  "day_structure": {
    "phases": [
      {
        "id": "morning",
        "label": "Morgen",
        "clock_anchor": "06:00",
        "target_minutes": 10,
        "mail_slots": [
          {
            "slot": "morning_brief",
            "type": "story_or_context",
            "count": 1,
            "purpose": "Dagens brief, rolle og carryover."
          },
          {
            "slot": "first_message",
            "type": "people",
            "count": 1,
            "purpose": "Første melding fra person eller miljø."
          },
          {
            "slot": "preparation",
            "type": "micro_choice",
            "count": 1,
            "purpose": "Forberedelse før arbeid starter."
          },
          {
            "slot": "day_goal_choice",
            "type": "micro_choice",
            "count": 1,
            "purpose": "Valg av dagens mål."
          }
        ]
      },
      {
        "id": "forenoon",
        "label": "Formiddag",
        "clock_anchor": "09:00",
        "target_minutes": 12,
        "mail_slots": [
          {
            "slot": "primary_work_mail",
            "type": "job",
            "count": 1,
            "purpose": "Viktig jobbmail eller hovedsak tidlig på dagen."
          },
          {
            "slot": "operational_mail",
            "type": "job_micro",
            "count": 1,
            "purpose": "Operativ avklaring."
          },
          {
            "slot": "people_ping",
            "type": "people",
            "count": 1,
            "purpose": "Kollega/person ber om avklaring."
          },
          {
            "slot": "small_choice",
            "type": "micro_choice",
            "count": 1,
            "purpose": "Lite faglig/praktisk valg."
          }
        ]
      },
      {
        "id": "workday",
        "label": "Arbeidsdag",
        "clock_anchor": "10:00",
        "target_minutes": 18,
        "mail_slots": [
          {
            "slot": "main_delivery",
            "type": "job",
            "count": 1,
            "purpose": "Dagens hovedleveranse."
          },
          {
            "slot": "task_gate",
            "type": "task_gate",
            "count": 1,
            "purpose": "Oppgaveport som må fullføres hvis opprettet."
          },
          {
            "slot": "conflict_or_event",
            "type": "conflict_or_event",
            "count": 1,
            "purpose": "Konflikt, møte eller hendelse."
          },
          {
            "slot": "analysis_followup",
            "type": "followup",
            "count": 1,
            "purpose": "Faglig oppfølging/analyse."
          },
          {
            "slot": "operational_batch",
            "type": "job_micro",
            "count": 1,
            "purpose": "Samlet operativ arbeidsbunke."
          }
        ]
      },
      {
        "id": "lunch",
        "label": "Lunsj",
        "clock_anchor": "12:00",
        "target_minutes": 8,
        "mail_slots": [
          {
