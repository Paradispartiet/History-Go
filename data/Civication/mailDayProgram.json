  },
  "daily_mail_volume": {
    "target_total_items_per_day_min": 18,
    "target_total_items_per_day_max": 26,
    "recommended_total_items_per_day": 22,
    "recommended_mix": {
      "long_role_mails": 3,
      "medium_followups_or_conflicts": 4,
      "micro_operational_mails": 8,
      "people_or_status_mails": 3,
      "phase_events": 3,
      "day_end_summary": 1
    },
    "notes": [
      "Dette betyr ikke 22 store mailer. Dagen bør ha 3–5 store/medium mailer og mange små operative mailer.",
      "Micro-mails bør være korte, men konkrete: et spørsmål, en rapportlinje, en avklaring, en reaksjon eller en liten konflikt.",
      "Store role-mails skal fortsatt komme fra mailPlan/mailFamilies og drive rolleprogresjonen."
    ]
  },
  "role_content_requirements": {
    "minimum_days_per_role": 8,
    "target_days_per_role": 12,
    "future_target_days_per_role": 16,
    "required_content_per_role_for_12_days": {
      "long_role_mails_min": 36,
      "medium_followups_min": 48,
      "micro_operational_mails_min": 96,
      "people_or_status_mails_min": 36,
      "phase_or_dayend_generated": true
    },
    "notes": [
      "De fire finansrollene har nå rolleprogresjon, men ikke nok mailvolum til 12 fulle dager per rolle.",
      "Neste byggesteg bør ikke bare lage nye roller. Det bør utvide hver eksisterende rolle med micro-, followup-, people- og consequence-mails."
    ]
  },
  "implementation_plan": [
    {
      "step": 1,
      "title": "Behold mailPlan som hovedprogresjon",
      "description": "Ikke gjør 60 plansteg per rolle. Planen skal fortsatt være dramaturgisk hovedløype."
    },
    {
      "step": 2,
      "title": "Legg til daily mail builder",
      "description": "Bygg en egen runtime som samler dagens mailpakke fra rolePlan, roleModel, phase-events, life-mails, people-mails og micro-mails."
    },
    {
      "step": 3,
      "title": "Legg til micro- og followup-familier",
      "description": "Hver rolle bør få egne micro- og followup-filer, for eksempel data/Civication/mailFamilies/naeringsliv/micro/controller_micro.json."
    },
    {
      "step": 4,
      "title": "Valider lesetid",
      "description": "Lag validator som teller ord per rolle/dagprogram og varsler hvis rollen ikke kan fylle 60 minutter."
    },
    {
      "step": 5,
      "title": "UI skal vise dagsbunke",
      "description": "Innboksen bør kunne vise dagens mailer som Morgen, Lunsj, Ettermiddag, Kveld og Dagslutt, ikke bare én pending mail."
    }
  ]
}
