      "kommersialisering av kultur",
      "subkulturer som blir pynt eller fjernet"
    ],
    "methods": [
      "diskursanalyse",
      "visuell analyse",
      "medieanalyse",
      "feltobservasjon",
      "historisk sammenligning"
    ],
    "analysis_axes": [
      "autentisitet vs iscenesettelse",
      "lokal identitet vs ekstern merkevare",
      "inkluderende narrativ vs ekskluderende narrativ"
    ],
