      "image management",
      "autentisitet",
      "iscenesettelse",
      "turistifisering",
      "kulturell hegemonisering",
      "kulturell kapital"
    ],
    "related_routes": [],
    "related_places": [],
    "related_quizzes": [],
    "status": "core",
    "learning_goals": [
      {
        "goal_id": "g_by_symbolsk_1",
        "title": "Forstå symbolsk makt som bylogikk",
        "core_concepts": [
          "symbolsk kapital",
          "representasjon",
          "stedsidentitet"
        ],
        "success_criteria": [
          "Kan forklare hva symbolsk makt betyr med egne ord",
          "Kan identifisere minst 2 konkrete representasjoner i byrommet (skilt, arkitektur, navn, reklame, kunst)",
          "Kan knytte representasjon til en sosial konsekvens (hvem inviteres, hvem skyves ut)"
        ],
        "concepts": [
          "symbolsk kapital",
          "representasjon",
          "stedsidentitet"
        ]
      },
      {
        "goal_id": "g_by_symbolsk_2",
        "title": "Analysere hvordan narrativ og estetikk styrer tilgang og status",
        "core_concepts": [
          "branding",
          "narrativ",
          "estetisk politikk"
        ],
        "success_criteria": [
          "Kan beskrive hvilket narrativ et område kommuniserer (for hvem, med hvilke signaler)",
          "Kan peke på minst én blindspot (hvem som forsvinner i fortellingen)",
          "Kan gi én alternativ tolkning eller kritikk av representasjonen"
        ],
        "concepts": [
          "branding",
          "narrativ",
          "estetisk politikk"
        ]
      },
      {
        "goal_id": "g_by_symbolsk_3",
        "title": "Anvende metoder på et konkret sted",
        "core_concepts": [
          "representasjon",
          "branding",
          "autentisitet"
        ],
        "success_criteria": [
          "Har gjort en kort feltlogg (foto/notat) av symboler og signaler",
          "Kan lage en enkel kontrast: 'hvordan stedet omtales' vs 'hvordan stedet brukes'",
          "Kan formulere ett spørsmål som kan testes med ny runde (f.eks. hvem som føler seg hjemme her)"
        ],
        "concepts": [
          "representasjon",
          "branding",
          "autentisitet"
        ]
      }
    ],
    "checkpoints": [
      {
