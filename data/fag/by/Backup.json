        "cp_id": "cp_by_symbolsk_4",
        "title": "Kryssanalyse: praksis vs representasjon",
        "type": "reflection",
        "criteria": "Beskriv ett konkret misforhold mellom hvordan stedet brukes og hvordan det fremstilles.",
        "related_goals": [
          "g_by_symbolsk_2",
