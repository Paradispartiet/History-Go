{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": [
      "ES2022"
    ],
    "types": [
      "node"
    ],
    "allowJs": false,
    "checkJs": false,
    "noEmit": true,
    "strict": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": false,
    "esModuleInterop": true
  },
  "include": [
    "tools/check_place_emne_ids.mts",
    "tools/check_duplicate_json_keys.mts",
    "tools/check_leksikon_duplicate_ids.mts",
    "tools/check_place_id_aliases.mts",
    "tools/check_stories_integrity.mts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "build",
    ".cache",
    "js/**",
    "js/Civication/**",
    "tools/*civication*.js",
    "tools/*civication*.ts",
    "tools/*civication*.mts",
    "tools/*civication*.cts",
    "tools/**/*civication*.js",
    "tools/**/*civication*.ts",
    "tools/**/*civication*.mts",
    "tools/**/*civication*.cts"
  ]
}
