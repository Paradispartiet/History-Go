{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": [
      "ES2022"
    ],
    "types": [
      "node"
    ],
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": false,
    "esModuleInterop": true
  },
  "include": [
    "scripts/i18n-*.js",
    "scripts/audit-wonderkammer-data.mjs",
    "scripts/**/*.ts",
    "scripts/**/*.mts",
    "scripts/**/*.cts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "build",
    ".cache",
    "js/**",
    "js/Civication/**",
    "scripts/*civication*.js",
    "scripts/*civication*.ts",
    "scripts/*civication*.mts",
    "scripts/*civication*.cts",
    "scripts/**/*civication*.js",
    "scripts/**/*civication*.ts",
    "scripts/**/*civication*.mts",
    "scripts/**/*civication*.cts"
  ]
}
