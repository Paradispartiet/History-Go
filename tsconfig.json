{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": [
    "js/**/*.js",
    "scripts/**/*.js",
    "*.js",
    "schemas/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "build",
    ".cache"
  ]
}
